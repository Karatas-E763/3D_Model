# Variables de entorno — DirectTrack

## Administración
ADMIN_USERNAME=admin
ADMIN_PASSWORD=directtrack2024
AUTH_SECRET=cambiar-por-un-secreto-seguro-en-produccion

## Correo (envío de cotizaciones — use una opción)

# Opción A: Resend (recomendado, entrega en segundos)
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=DirectTrack <ventas@directtrack.mx>

# Opción B: SMTP tradicional
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ventas@directtrack.mx
SMTP_PASS=contraseña-smtp
SMTP_FROM=ventas@directtrack.mx

## CMS en Vercel (persistencia JSON en data/cms del repositorio)
# Token de GitHub con permiso repo (Contents: read/write). Requerido en Vercel para guardar cambios del admin.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Opcional si el repositorio no se detecta automáticamente:
# GITHUB_REPO_OWNER=tu-usuario
# GITHUB_REPO=tu-repositorio
# GITHUB_BRANCH=main
